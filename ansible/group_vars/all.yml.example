---
app_name: loja
app_title: "Packet Loss Store"
app_domain: "loja.packetloss.com.br"
api_domain: "api.loja.packetloss.com.br"

# Paths and runtime
app_dir: /var/www/loja.packetloss.com.br
backend_port: 9000
storefront_port: 8000
node_env: production

# TLS cert paths (Let's Encrypt default)
nginx_ssl_certificate: "/etc/letsencrypt/live/loja.packetloss.com.br/fullchain.pem"
nginx_ssl_certificate_key: "/etc/letsencrypt/live/loja.packetloss.com.br/privkey.pem"

# Runtime secrets - override in CI/extra vars
medusa_jwt_secret: "change-me"
medusa_cookie_secret: "change-me"
medusa_store_cors: "https://loja.packetloss.com.br"
medusa_admin_cors: "https://loja.packetloss.com.br"
medusa_auth_cors: "https://loja.packetloss.com.br"
medusa_database_url: ""
medusa_redis_url: "redis://127.0.0.1:6379"
medusa_publishable_key: ""
default_region: "br"

# Runtime OS user/group
app_user: nginx
app_group: nginx
